{{- $bitwardenData := (get . "bitwarden" | default (dict)) -}}
{{- $profileData := (get . "profile" | default (dict)) -}}
{{- $profilesData := (get . "profiles" | default (dict)) -}}
{{- $activeProfile := (env "DOTFILES_PROFILE" | default (get $profileData "active") | default "" | trim) -}}
{{- $activeProfileData := dict -}}
{{- if ne $activeProfile "" -}}
{{- if not (hasKey $profilesData $activeProfile) -}}
{{- fail (printf "DOTFILES_PROFILE/profile.active %q is not defined in data.profiles" $activeProfile) -}}
{{- end -}}
{{- $activeProfileData = (get $profilesData $activeProfile | default (dict)) -}}
{{- end -}}
{{- $runtimeItemID := (env "BW_RUNTIME_ENV_ITEM_ID" | default (get $activeProfileData "runtimeEnvItemId") | default (get $bitwardenData "runtimeEnvItemId") | default "" | trim) -}}
{{- $runtimeFields := (get $activeProfileData "runtimeEnvFields" | default (get $bitwardenData "runtimeEnvFields") | default (list "CONTEXT7_API_KEY" "GITHUB_TOKEN")) -}}
{{- $retiredRuntimeFields := list "ANTHROPIC_API_KEY" "OPENAI_API_KEY" "CLOUDFLARE_API_TOKEN" "CLOUDFLARE_ACCOUNT_ID" "AWS_ACCESS_KEY_ID" "AWS_SECRET_ACCESS_KEY" "AWS_SESSION_TOKEN" -}}
{{- $hasBitwardenSession := ne (env "BW_SESSION" | default "" | trim) "" -}}
{{- $hasBitwardenCLI := ne (lookPath "bw") "" -}}
# Managed by chezmoi. Source values come from Bitwarden custom fields.
{{- if ne $activeProfile "" }}
# Active profile: {{ $activeProfile }}
{{- end }}
{{- if and (ne $runtimeItemID "") $hasBitwardenSession $hasBitwardenCLI }}
{{- $fields := bitwardenFields "item" $runtimeItemID -}}
{{- range $name := $runtimeFields }}
{{- if not (has $name $retiredRuntimeFields) }}
{{- if hasKey $fields $name }}
{{- $value := (get (get $fields $name) "value" | toString) -}}
{{- if and (ne $value "") (not (contains "\n" $value)) }}
set -gx {{ $name }} '{{ $value | replace "\\" "\\\\" | replace "'" "\\'" }}'
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- else }}
# Bitwarden is not configured or unlocked. No secret environment variables rendered.
{{- end }}
