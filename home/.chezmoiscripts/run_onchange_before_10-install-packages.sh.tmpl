{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

set -euo pipefail

load_homebrew_env() {
  local brew_bin

  for brew_bin in \
    /home/linuxbrew/.linuxbrew/bin/brew \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew
  do
    if [[ -x "$brew_bin" ]]; then
      eval "$("$brew_bin" shellenv)"
      return
    fi
  done
}

{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") (or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "raspbian") (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "zorin")) }}
if command -v apt-get >/dev/null 2>&1; then
  sudo apt-get update
  sudo apt-get install -y \
    build-essential \
    ca-certificates \
    curl \
    file \
    git \
    libicu-dev \
    procps \
    unzip
fi
{{ end }}

if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

load_homebrew_env

brew bundle --file=/dev/stdin <<'BREWFILE'
brew "chezmoi"
brew "fish"
brew "fisher"
brew "gmailctl"
brew "jsonnet"
brew "mise"
brew "zoxide"
BREWFILE
{{ end -}}
