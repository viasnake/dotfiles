{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

set -euo pipefail

is_root() {
  [[ ${EUID:-$(id -u)} -eq 0 ]]
}

load_homebrew_env() {
  local brew_bin

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
    return
  fi

  for brew_bin in \
    /home/linuxbrew/.linuxbrew/bin/brew \
    "$HOME/.linuxbrew/bin/brew" \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew
  do
    if [[ -x "$brew_bin" ]]; then
      eval "$("$brew_bin" shellenv)"
      return
    fi
  done
}

{{- if and (eq .chezmoi.os "linux") (hasKey .chezmoi.osRelease "id") (or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "raspbian") (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "zorin")) }}
if command -v apt-get >/dev/null 2>&1; then
  apt_cmd=(sudo)
  if is_root; then
    apt_cmd=()
  fi

  "${apt_cmd[@]}" env DEBIAN_FRONTEND=noninteractive TZ=Etc/UTC apt-get update
  "${apt_cmd[@]}" env DEBIAN_FRONTEND=noninteractive TZ=Etc/UTC apt-get install -y \
    build-essential \
    ca-certificates \
    curl \
    file \
    fish \
    git \
    jq \
    libicu-dev \
    procps \
    unzip \
    zoxide
fi
{{ end }}

if is_root; then
  printf '%s\n' '[install-packages] root実行のためHomebrewはスキップし、OSパッケージを優先します'
else
  if ! command -v brew >/dev/null 2>&1; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi

  load_homebrew_env

  brew bundle --file=/dev/stdin <<'BREWFILE'
brew "chezmoi"
brew "fish"
brew "fisher"
brew "gmailctl"
brew "jsonnet"
brew "mise"
brew "zoxide"
BREWFILE
fi
{{ end -}}
