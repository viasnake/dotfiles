{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

set -euo pipefail

plugins_file="$HOME/.config/fish/fish_plugins"
# fish_plugins hash: {{ include "dot_config/fish/fish_plugins" | sha256sum }}

if ! command -v fish >/dev/null 2>&1; then
  exit 0
fi

if [[ ! -f "$plugins_file" ]]; then
  exit 0
fi

plugins="$(tr '\n' ' ' < "$plugins_file")"
if [[ -z "${plugins// }" ]]; then
  exit 0
fi

fish -c "fisher install $plugins"
{{ end -}}
