{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash

set -euo pipefail

load_homebrew_env() {
  local brew_bin

  if command -v brew >/dev/null 2>&1; then
    eval "$(brew shellenv)"
    return
  fi

  for brew_bin in \
    /home/linuxbrew/.linuxbrew/bin/brew \
    "$HOME/.linuxbrew/bin/brew" \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew
  do
    if [[ -x "$brew_bin" ]]; then
      eval "$("$brew_bin" shellenv)"
      return
    fi
  done
}

current_login_shell() {
  local user_name="$1"

  if command -v getent >/dev/null 2>&1; then
    getent passwd "$user_name" | awk -F: '{ print $7 }'
    return
  fi

  if command -v dscl >/dev/null 2>&1; then
    dscl . -read "/Users/$user_name" UserShell 2>/dev/null | awk '{ print $2 }'
  fi
}

change_login_shell() {
  local fish_path="$1"
  local user_name="$2"

  if [[ "$(id -u)" -eq 0 ]]; then
    chsh -s "$fish_path" "$user_name"
  else
    sudo chsh -s "$fish_path" "$user_name"
  fi
}

load_homebrew_env

if ! command -v fish >/dev/null 2>&1; then
  exit 0
fi

fish_path="$(command -v fish)"
user_name="${USER:-$(id -un)}"

if ! grep -qxF "$fish_path" /etc/shells; then
  echo "$fish_path" | sudo tee -a /etc/shells >/dev/null
fi

if [[ "$(current_login_shell "$user_name")" != "$fish_path" ]]; then
  change_login_shell "$fish_path" "$user_name"
fi
{{ end -}}
