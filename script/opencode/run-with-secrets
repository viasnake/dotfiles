#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

"$SCRIPT_DIR/validate"

source "$REPO_ROOT/script/lib/load-secrets-env"

load_runtime_secrets_env

profile="${OCX_PROFILE:-personal}"

if ! [[ "$profile" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
  echo "[ERROR] invalid OCX_PROFILE value: $profile" >&2
  exit 1
fi

if [[ ! -f "$REPO_ROOT/config/opencode/profiles/$profile/ocx.jsonc" ]]; then
  echo "[ERROR] unknown profile '$profile' in config/opencode/profiles" >&2
  exit 1
fi

if ! command -v ocx >/dev/null 2>&1; then
  echo "[ERROR] ocx command not found" >&2
  exit 1
fi

exec ocx oc -p "$profile" "$@"
