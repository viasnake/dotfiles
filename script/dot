#!/usr/bin/env bash

set -euo pipefail

DOT_SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_REPO_ROOT="$(cd "$DOT_SELF_DIR/.." && pwd)"

DOT_CONFIG_ROOT="${DOT_CONFIG_ROOT:-$HOME/.config/dotfiles}"
DOT_PUBLIC_LINK="$DOT_CONFIG_ROOT/dotfiles-public"

DOT_EXIT_SUCCESS=0
DOT_EXIT_ERROR=1

info() {
  printf '[INFO] %s\n' "$1"
}

error() {
  printf '[ERROR] %s\n' "$1" >&2
}

usage() {
  cat <<'EOF'
Usage:
  dot bootstrap
  dot help
EOF
}

ensure_dir() {
  mkdir -p "$1"
}

validate_no_args() {
  if [ -n "${1:-}" ]; then
    error "Unknown option: $1"
    exit "$DOT_EXIT_ERROR"
  fi
}

bootstrap() {
  validate_no_args "${1:-}"

  ensure_dir "$DOT_CONFIG_ROOT"
  ln -nfs "$DOT_REPO_ROOT" "$DOT_PUBLIC_LINK"
  info "Linked public repository: $DOT_PUBLIC_LINK"

  "$DOT_REPO_ROOT/script/bootstrap" link
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    bootstrap)
      bootstrap "${1:-}"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit "$DOT_EXIT_ERROR"
      ;;
  esac

  exit "$DOT_EXIT_SUCCESS"
}

main "$@"
