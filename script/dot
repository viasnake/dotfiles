#!/usr/bin/env bash

set -euo pipefail

DOT_SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOT_REPO_ROOT="$(cd "$DOT_SELF_DIR/.." && pwd)"

DOT_CONFIG_ROOT="${DOT_CONFIG_ROOT:-$HOME/.config/dotfiles}"
DOT_FLAGS_DIR="$DOT_CONFIG_ROOT/flags"
DOT_WORK_FLAG_FILE="$DOT_FLAGS_DIR/work_enabled"
DOT_PROFILES_DIR="$DOT_CONFIG_ROOT/profiles.d"
DOT_PUBLIC_LINK="$DOT_CONFIG_ROOT/dotfiles-public"
DOT_WORK_DIR="${DOT_WORK_DIR:-$DOT_CONFIG_ROOT/dotfiles-work}"
DOT_WORK_REPO_URL="${DOT_WORK_REPO_URL:-}"

DOT_SSH_DIR="$HOME/.ssh"
DOT_SSH_CONFIG_D_DIR="$DOT_SSH_DIR/config.d"
DOT_WORK_CONFIG_SOURCE="$DOT_WORK_DIR/ssh/config.d/10-work.conf"
DOT_WORK_CONFIG_TARGET="$DOT_SSH_CONFIG_D_DIR/10-work.conf"
DOT_WORK_GITCONFIG_SOURCE="$DOT_WORK_DIR/git/gitconfig.work"
DOT_WORK_GITCONFIG_TARGET="$HOME/.gitconfig.work"
DOT_WORK_PROFILE_SOURCE="$DOT_WORK_DIR/profiles.d/work.sh"
DOT_WORK_PROFILE_TARGET="$DOT_PROFILES_DIR/work.sh"

DOT_SSH_PERSONAL_ITEM_DEFAULT="personal-ssh"
DOT_SSH_WORK_ITEM_DEFAULT="work-ssh"

DOT_EXIT_SUCCESS=0
DOT_EXIT_ERROR=1

USE_AGENT=0

info() {
  printf '[INFO] %s\n' "$1"
}

warn() {
  printf '[WARN] %s\n' "$1" >&2
}

error() {
  printf '[ERROR] %s\n' "$1" >&2
}

usage() {
  cat <<'EOF'
Usage:
  dot bootstrap [--agent]
  dot work enable|disable|status|sync
  dot ssh sync [--agent]
  dot ssh status
  dot ssh test
  dot help

Environment variables:
  DOT_WORK_REPO_URL        Work repo URL (required for initial clone)
  DOT_SSH_PERSONAL_ITEM    Bitwarden SSH key item ID/name for personal key
  DOT_SSH_WORK_ITEM        Bitwarden SSH key item ID/name for work key
  WORK_PROFILE             Set to 1 to treat work profile as enabled
EOF
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    error "Required command not found: $1"
    exit "$DOT_EXIT_ERROR"
  fi
}

ensure_dir() {
  mkdir -p "$1"
}

is_work_enabled() {
  if [ -f "$DOT_WORK_FLAG_FILE" ]; then
    return 0
  fi

  if [ "${WORK_PROFILE:-0}" = "1" ]; then
    return 0
  fi

  return 1
}

link_if_exists() {
  local source_file="$1"
  local target_file="$2"

  if [ ! -f "$source_file" ]; then
    warn "Skip link, source not found: $source_file"
    return 1
  fi

  ensure_dir "$(dirname "$target_file")"
  ln -nfs "$source_file" "$target_file"
  info "Linked $target_file"
  return 0
}

unlink_if_exists() {
  local target_file="$1"
  if [ -L "$target_file" ] || [ -f "$target_file" ]; then
    rm -f "$target_file"
    info "Removed $target_file"
  fi
}

sync_work_repo() {
  require_cmd git
  ensure_dir "$DOT_CONFIG_ROOT"

  if [ -d "$DOT_WORK_DIR/.git" ]; then
    info "Updating work repository"
    git -C "$DOT_WORK_DIR" pull --ff-only
    return 0
  fi

  if [ -z "$DOT_WORK_REPO_URL" ]; then
    warn "DOT_WORK_REPO_URL is not set, skipping work repository clone"
    return 1
  fi

  info "Cloning work repository"
  git clone "$DOT_WORK_REPO_URL" "$DOT_WORK_DIR"
}

sync_work_links() {
  local linked=0

  link_if_exists "$DOT_WORK_CONFIG_SOURCE" "$DOT_WORK_CONFIG_TARGET" && linked=1 || true
  link_if_exists "$DOT_WORK_GITCONFIG_SOURCE" "$DOT_WORK_GITCONFIG_TARGET" && linked=1 || true
  link_if_exists "$DOT_WORK_PROFILE_SOURCE" "$DOT_WORK_PROFILE_TARGET" && linked=1 || true

  if [ "$linked" -eq 0 ]; then
    warn "No work files were linked"
    return 1
  fi

  return 0
}

work_enable() {
  ensure_dir "$DOT_FLAGS_DIR"
  touch "$DOT_WORK_FLAG_FILE"
  info "Work profile enabled"
}

work_disable() {
  rm -f "$DOT_WORK_FLAG_FILE"
  unlink_if_exists "$DOT_WORK_CONFIG_TARGET"
  unlink_if_exists "$DOT_WORK_GITCONFIG_TARGET"
  unlink_if_exists "$DOT_WORK_PROFILE_TARGET"
  info "Work profile disabled"
}

work_status() {
  if is_work_enabled; then
    info "work_enabled=true"
  else
    info "work_enabled=false"
  fi

  if [ -d "$DOT_WORK_DIR/.git" ]; then
    info "work_repo=present ($DOT_WORK_DIR)"
  else
    info "work_repo=missing ($DOT_WORK_DIR)"
  fi

  for target in "$DOT_WORK_CONFIG_TARGET" "$DOT_WORK_GITCONFIG_TARGET" "$DOT_WORK_PROFILE_TARGET"; do
    if [ -L "$target" ] || [ -f "$target" ]; then
      info "present: $target"
    else
      info "missing: $target"
    fi
  done
}

work_sync() {
  if ! sync_work_repo; then
    warn "Work repository sync skipped"
    return 1
  fi

  sync_work_links || true
  return 0
}

bw_status_check() {
  require_cmd bw
  require_cmd jq

  local status_json
  status_json="$(bw status 2>/dev/null || true)"

  if [ -z "$status_json" ]; then
    error "Bitwarden CLI is not logged in"
    error "Run: bw login && bw unlock --raw"
    return 1
  fi

  local state
  state="$(printf '%s' "$status_json" | jq -r '.status // empty')"
  if [ "$state" != "unlocked" ]; then
    error "Bitwarden vault is not unlocked (status=$state)"
    error "Run: bw unlock --raw"
    return 1
  fi

  return 0
}

resolve_bw_item() {
  local query="$1"
  local item_json

  item_json="$(bw get item "$query" 2>/dev/null || true)"
  if [ -n "$item_json" ]; then
    printf '%s' "$item_json"
    return 0
  fi

  item_json="$(bw list items --search "$query" 2>/dev/null | jq '.[0] // empty')"
  if [ -n "$item_json" ] && [ "$item_json" != "null" ]; then
    printf '%s' "$item_json"
    return 0
  fi

  return 1
}

extract_ssh_keypair() {
  local item_json="$1"
  local key_kind="$2"

  if [ "$key_kind" = "private" ]; then
    printf '%s' "$item_json" | jq -r '.sshKey.privateKey // .sshKey.keyPair.privateKey // .keyPair.privateKey // empty'
    return 0
  fi

  if [ "$key_kind" = "public" ]; then
    printf '%s' "$item_json" | jq -r '.sshKey.publicKey // .sshKey.keyPair.publicKey // .keyPair.publicKey // empty'
    return 0
  fi

  return 1
}

write_keypair() {
  local private_key="$1"
  local public_key="$2"
  local private_path="$3"

  ensure_dir "$DOT_SSH_DIR"
  chmod 700 "$DOT_SSH_DIR"

  printf '%s\n' "$private_key" > "$private_path"
  chmod 600 "$private_path"

  printf '%s\n' "$public_key" > "$private_path.pub"
  chmod 600 "$private_path.pub"

  info "Wrote keypair: $private_path"
}

sync_single_ssh_key() {
  local label="$1"
  local lookup="$2"
  local private_path="$3"

  local item_json
  item_json="$(resolve_bw_item "$lookup" || true)"
  if [ -z "$item_json" ]; then
    warn "Skip $label key, Bitwarden item not found: $lookup"
    return 1
  fi

  local item_type
  item_type="$(printf '%s' "$item_json" | jq -r '.type // empty')"
  if [ "$item_type" != "5" ]; then
    warn "Skip $label key, item is not SSH key type (type=$item_type)"
    return 1
  fi

  local private_key
  local public_key
  private_key="$(extract_ssh_keypair "$item_json" "private")"
  public_key="$(extract_ssh_keypair "$item_json" "public")"

  if [ -z "$private_key" ] || [ -z "$public_key" ]; then
    warn "Skip $label key, missing ssh keypair values in item"
    return 1
  fi

  write_keypair "$private_key" "$public_key" "$private_path"

  if [ "$USE_AGENT" -eq 1 ]; then
    if ssh-add "$private_path" >/dev/null 2>&1; then
      info "Added to ssh-agent: $private_path"
    else
      warn "Failed to add to ssh-agent: $private_path"
    fi
  fi

  return 0
}

file_mode() {
  local file_path="$1"
  local mode

  mode="$(stat -c '%a' "$file_path" 2>/dev/null || true)"
  if [ -n "$mode" ]; then
    printf '%s' "$mode"
    return 0
  fi

  mode="$(stat -f '%Lp' "$file_path" 2>/dev/null || true)"
  printf '%s' "$mode"
}

print_key_status() {
  local label="$1"
  local private_path="$2"
  local public_path="$private_path.pub"

  if [ ! -f "$private_path" ] || [ ! -f "$public_path" ]; then
    info "$label key: missing"
    return 0
  fi

  local private_mode
  local public_mode
  local fingerprint
  private_mode="$(file_mode "$private_path")"
  public_mode="$(file_mode "$public_path")"
  fingerprint="$(ssh-keygen -lf "$public_path" 2>/dev/null | cut -d ' ' -f2 || true)"

  info "$label key: present private_mode=$private_mode public_mode=$public_mode fingerprint=$fingerprint"
}

ssh_sync() {
  require_cmd ssh-keygen
  bw_status_check || return 1

  local personal_lookup="${DOT_SSH_PERSONAL_ITEM:-$DOT_SSH_PERSONAL_ITEM_DEFAULT}"
  local work_lookup="${DOT_SSH_WORK_ITEM:-$DOT_SSH_WORK_ITEM_DEFAULT}"

  sync_single_ssh_key "personal" "$personal_lookup" "$DOT_SSH_DIR/id_ed25519_personal" || true

  if is_work_enabled; then
    sync_single_ssh_key "work" "$work_lookup" "$DOT_SSH_DIR/id_ed25519_work" || true
  else
    info "Work profile is disabled, skipping work key sync"
  fi
}

ssh_status() {
  print_key_status "personal" "$DOT_SSH_DIR/id_ed25519_personal"
  print_key_status "work" "$DOT_SSH_DIR/id_ed25519_work"
}

ssh_test() {
  require_cmd ssh

  if ssh -G github >/dev/null 2>&1; then
    info "ssh config check passed for host: github"
  else
    warn "ssh config check failed for host: github"
  fi

  local work_host="${DOT_SSH_TEST_WORK_HOST:-}"
  if [ -n "$work_host" ]; then
    if ssh -G "$work_host" >/dev/null 2>&1; then
      info "ssh config check passed for host: $work_host"
    else
      warn "ssh config check failed for host: $work_host"
    fi
  else
    info "DOT_SSH_TEST_WORK_HOST is not set, skipping work host check"
  fi
}

parse_agent_flag() {
  if [ "${1:-}" = "--agent" ]; then
    USE_AGENT=1
    return 0
  fi

  if [ -n "${1:-}" ]; then
    error "Unknown option: $1"
    exit "$DOT_EXIT_ERROR"
  fi
}

bootstrap() {
  parse_agent_flag "${1:-}"

  ensure_dir "$DOT_CONFIG_ROOT"
  ln -nfs "$DOT_REPO_ROOT" "$DOT_PUBLIC_LINK"
  info "Linked public repository: $DOT_PUBLIC_LINK"

  "$DOT_REPO_ROOT/script/bootstrap" link

  if is_work_enabled; then
    work_sync || warn "Work sync failed during bootstrap"
  else
    info "Work profile is disabled, skipping work sync"
  fi

  ssh_sync || warn "SSH sync failed during bootstrap"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    bootstrap)
      bootstrap "${1:-}"
      ;;
    work)
      case "${1:-}" in
        enable)
          work_enable
          ;;
        disable)
          work_disable
          ;;
        status)
          work_status
          ;;
        sync)
          work_sync
          ;;
        *)
          usage
          exit "$DOT_EXIT_ERROR"
          ;;
      esac
      ;;
    ssh)
      case "${1:-}" in
        sync)
          shift || true
          parse_agent_flag "${1:-}"
          ssh_sync
          ;;
        status)
          ssh_status
          ;;
        test)
          ssh_test
          ;;
        *)
          usage
          exit "$DOT_EXIT_ERROR"
          ;;
      esac
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit "$DOT_EXIT_ERROR"
      ;;
  esac

  exit "$DOT_EXIT_SUCCESS"
}

main "$@"
