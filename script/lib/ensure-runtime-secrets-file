#!/usr/bin/env bash

set -euo pipefail

default_runtime_secrets_dir() {
  printf "%s" "${HOME}/.config/secrets"
}

default_runtime_secrets_file() {
  printf "%s/runtime.env.secret" "$(default_runtime_secrets_dir)"
}

ensure_runtime_secrets_file() {
  local secrets_dir
  local secrets_file

  secrets_dir="$(default_runtime_secrets_dir)"
  secrets_file="$(default_runtime_secrets_file)"

  mkdir -p "$secrets_dir"
  chmod 700 "$secrets_dir"

  if [[ -e "$secrets_file" ]]; then
    return 0
  fi

  cat > "$secrets_file" <<'EOF'
# Runtime environment secrets for local tools
# Format: KEY=VALUE
# Example:
# CONTEXT7_API_KEY=<your-context7-api-key>
EOF

  chmod 600 "$secrets_file"
}
